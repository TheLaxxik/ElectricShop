---
const services = [
	{
		icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />`,
		title: 'Elektroinštalácie',
		description: 'Kompletné elektroinštalačné práce pre novostavby aj rekonštrukcie. Rodinné domy, byty, kancelárske priestory.',
		price: 'Od 25 €/hod',
	},
	{
		icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />`,
		title: 'Revízie a kontroly',
		description: 'Odborné revízie elektrických zariadení podľa platných noriem. Vydanie revíznej správy pre poisťovne a úrady.',
		price: 'Od 80 €',
	},
	{
		icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" />`,
		title: 'Opravy a poruchy',
		description: 'Rýchle odstránenie porúch elektrickej inštalácie. Výmena ističov, zásuviek, vypínačov a rozvádzačov.',
		price: 'Od 35 €',
	},
	{
		icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />`,
		title: 'Osvetlenie',
		description: 'Návrh a montáž osvetľovacích systémov. LED osvetlenie, inteligentné ovládanie, vonkajšie osvetlenie.',
		price: 'Od 20 €/hod',
	},
	{
		icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />`,
		title: 'Hromozvody',
		description: 'Inštalácia a revízia bleskozvodov pre rodinné domy a priemyselné objekty podľa STN noriem.',
		price: 'Od 150 €',
	},
	{
		icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" />`,
		title: 'Inteligentná domácnosť',
		description: 'Inštalácia smart home systémov — ovládanie osvetlenia, vykurovania a zabezpečenia cez mobil.',
		price: 'Od 200 €',
	},
];
---

<section class="py-12 sm:py-20" aria-labelledby="services-heading">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="mx-auto max-w-2xl text-center">
			<p class="text-sm font-semibold uppercase tracking-widest text-yellow-500">Čo robíme</p>
			<h2 id="services-heading" class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
				Naše služby
			</h2>
			<p class="mt-4 text-lg text-slate-600 dark:text-neutral-400">
				Poskytujeme komplexné elektroinštalačné služby pre domácnosti aj firmy v Košiciach a okolí.
			</p>
		</div>

		<div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{services.map((service) => (
				<article class="group flex flex-col gap-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-md dark:border-neutral-800 dark:bg-neutral-900">
					<div class="flex h-12 w-12 items-center justify-center rounded-xl bg-yellow-100 text-yellow-600 dark:bg-yellow-500/10 dark:text-yellow-400">
						<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
							<Fragment set:html={service.icon} />
						</svg>
					</div>
					<div class="flex flex-col gap-2">
						<h3 class="text-lg font-semibold text-slate-900 dark:text-white">{service.title}</h3>
						<p class="text-sm leading-relaxed text-slate-600 dark:text-neutral-400">{service.description}</p>
					</div>
					<div class="mt-auto pt-2">
						<span class="inline-flex items-center rounded-full bg-yellow-50 px-3 py-1 text-sm font-semibold text-yellow-700 dark:bg-yellow-500/10 dark:text-yellow-400">
							{service.price}
						</span>
					</div>
				</article>
			))}
		</div>

		<div class="mt-10 text-center">
			<a href="/kontakt" class="inline-flex items-center justify-center rounded-lg bg-yellow-500 px-6 py-3 text-base font-semibold text-black shadow-sm transition-all hover:bg-yellow-400 hover:shadow-md">
				Získať cenovú ponuku
			</a>
		</div>
	</div>
</section>