---
interface Props {
	showHeader?: boolean;
}

const { showHeader = true } = Astro.props;

const services = [
	{
		num: '01',
		title: 'Landing page',
		description:
			'Jednostránkový web s dôrazom na jasné posolstvo, jednoduchú navigáciu a konverziu.',
		price: 'od 250 €',
		icon: 'layout',
	},
	{
		num: '02',
		title: 'Firemný web',
		description:
			'Kompletný firemný web s prehľadnou štruktúrou, sekciami služieb a profesionálnou prezentáciou značky.',
		price: 'od 650 €',
		icon: 'building',
	},
	{
		num: '03',
		title: 'Zrýchlenie a úpravy',
		description:
			'Modernizácia dizajnu, responzivita, pridávanie podstránok alebo priebežná technická údržba.',
		price: 'od 200 €',
		icon: 'bolt',
	},
];
---

<section
	class:list={[showHeader ? 'py-16' : 'pb-16 pt-4', !showHeader && 'border-t-0']}
	aria-labelledby={showHeader ? 'services-heading' : undefined}
	aria-label={!showHeader ? 'Balíčky služieb' : undefined}
>
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		{
			showHeader && (
				<div class="mb-14 max-w-2xl">
					<p class="text-sm font-bold uppercase tracking-widest text-blue-600 dark:text-accent-warm">Služby</p>
					<h2
						id="services-heading"
						class="mt-3 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white"
					>
						Čo pre vás vieme vytvoriť
					</h2>
				</div>
			)
		}

		<ul class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3" role="list">
			{
				services.map((service) => (
					<li class="h-full">
						<article class="group relative flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200/80 bg-white p-8 shadow-sm transition-all duration-300 ease-out hover:-translate-y-1 hover:border-blue-200/80 hover:shadow-lg hover:shadow-blue-500/5 dark:border-neutral-800 dark:bg-black dark:shadow-none dark:hover:border-neutral-600 dark:hover:bg-neutral-950 dark:hover:shadow-none">
							<div
								class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-blue-500/0 to-transparent transition-all duration-300 group-hover:via-blue-500/60 dark:group-hover:via-accent-warm/70"
								aria-hidden="true"
							/>

							<div class="flex items-start justify-between gap-4">
								<span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-blue-50 text-sm font-bold tabular-nums text-blue-600 ring-1 ring-blue-100/80 dark:bg-neutral-900 dark:text-accent-warm dark:ring-neutral-800">
									{service.num}
								</span>
								<span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-slate-50 text-slate-500 ring-1 ring-slate-100 transition-colors group-hover:bg-blue-50 group-hover:text-blue-600 group-hover:ring-blue-100 dark:bg-neutral-900 dark:text-neutral-400 dark:ring-neutral-800 dark:group-hover:bg-neutral-800 dark:group-hover:text-accent-warm dark:group-hover:ring-neutral-700">
									{service.icon === 'layout' && (
										<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
											<path stroke-linecap="round" stroke-linejoin="round" d="M4 5h16M4 12h10M4 19h7" />
										</svg>
									)}
									{service.icon === 'building' && (
										<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M3 21h18M5 21V7l7-4 7 4v14M9 21v-6h6v6"
											/>
										</svg>
									)}
									{service.icon === 'bolt' && (
										<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
											<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
										</svg>
									)}
								</span>
							</div>

							<h3 class="mt-6 text-xl font-bold tracking-tight text-slate-900 dark:text-white">{service.title}</h3>
							<p class="mt-3 flex-1 text-base leading-relaxed text-slate-600 dark:text-neutral-400">
								{service.description}
							</p>

							<div class="mt-8 border-t border-slate-100 pt-6 dark:border-neutral-800">
								<p class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-neutral-500">Cena</p>
								<p class="mt-1 text-2xl font-bold tracking-tight text-slate-900 dark:text-white">{service.price}</p>
							</div>
						</article>
					</li>
				))
			}
		</ul>
	</div>
</section>
