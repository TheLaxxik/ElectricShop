---
const navLinks = [
	{ href: '/', label: 'Domov' },
	{ href: '/o-nas', label: 'O nás' },
	{ href: '/sluzby', label: 'Služby' },
	{ href: '/kontakt', label: 'Kontakt' },
];

const cta = { href: '/kontakt', label: 'Nezáväzná cenová ponuka' };
---

<script is:inline>
	(function () {
		try {
			if (localStorage.getItem('theme') === 'dark') {
				document.documentElement.classList.add('dark');
			}
		} catch (_) {}
	})();
</script>

<header class="sticky top-0 z-50 border-b border-transparent bg-white shadow-sm dark:border-neutral-800 dark:bg-black dark:shadow-none">
	<nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8" aria-label="Hlavná navigácia">
		<a
			href="/"
			class="shrink-0 text-xl font-bold tracking-tight text-slate-900 transition-colors hover:text-blue-600 dark:text-white dark:hover:text-neutral-300 sm:text-2xl"
		>
			Esticode
		</a>

		<ul class="hidden items-center gap-1 md:flex">
			{
				navLinks.map((link) => (
					<li>
						<a
							href={link.href}
							class="rounded-lg px-4 py-2 text-sm font-medium text-slate-600 transition-colors hover:bg-slate-50 hover:text-blue-600 dark:text-white dark:hover:bg-white/5 dark:hover:text-neutral-300"
						>
							{link.label}
						</a>
					</li>
				))
			}
		</ul>

		<div class="hidden items-center gap-3 md:flex">
			<button
				type="button"
				id="theme-toggle"
				class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-slate-100 text-slate-600 transition-colors hover:bg-slate-200 hover:text-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:border-neutral-700 dark:bg-neutral-900 dark:text-white dark:hover:border-neutral-500 dark:hover:bg-neutral-800 dark:focus-visible:outline-white"
				aria-label="Prepnúť tmavý režim"
			>
				<svg id="theme-icon-moon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
					/>
				</svg>
				<svg id="theme-icon-sun" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
					/>
				</svg>
			</button>
			<a
				href={cta.href}
				class="inline-flex shrink-0 rounded-lg bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-all duration-200 ease-out hover:bg-blue-700 hover:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:bg-white dark:text-black dark:shadow-none dark:hover:bg-neutral-100 dark:hover:shadow-none dark:focus-visible:outline-white"
			>
				{cta.label}
			</a>
		</div>

		<button
			type="button"
			id="nav-toggle"
			class="inline-flex items-center justify-center rounded-lg p-2 text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:text-white dark:hover:bg-white/5 dark:focus-visible:outline-white md:hidden"
			aria-expanded="false"
			aria-controls="mobile-menu"
			aria-label="Otvoriť menu"
		>
			<svg id="nav-icon-open" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
				<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
			<svg id="nav-icon-close" class="hidden h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>
	</nav>

	<div
		id="mobile-menu"
		class="hidden border-t border-slate-100 bg-white md:hidden dark:border-neutral-800 dark:bg-black"
		role="region"
		aria-label="Mobilné menu"
	>
		<ul class="flex flex-col gap-1 px-4 py-4 sm:px-6">
			{
				navLinks.map((link) => (
					<li>
						<a
							href={link.href}
							class="block rounded-lg px-4 py-3 text-base font-medium text-slate-600 transition-colors hover:bg-slate-50 hover:text-blue-600 dark:text-white dark:hover:bg-white/5 dark:hover:text-neutral-300"
						>
							{link.label}
						</a>
					</li>
				))
			}
			<li class="flex items-center gap-3 pt-2">
				<button
					type="button"
					id="theme-toggle-mobile"
					class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-slate-100 text-slate-600 transition-colors hover:bg-slate-200 hover:text-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 dark:border-neutral-700 dark:bg-neutral-900 dark:text-white dark:hover:border-neutral-500 dark:hover:bg-neutral-800 dark:focus-visible:outline-white"
					aria-label="Prepnúť tmavý režim"
				>
					<svg data-theme-icon="moon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
						/>
					</svg>
					<svg data-theme-icon="sun" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
						/>
					</svg>
				</button>
				<a
					href={cta.href}
					class="flex-1 rounded-lg bg-blue-600 px-4 py-3 text-center text-base font-semibold text-white shadow-sm transition-all duration-200 ease-out hover:bg-blue-700 hover:shadow-md dark:bg-white dark:text-black dark:shadow-none dark:hover:bg-neutral-100 dark:hover:shadow-none"
				>
					{cta.label}
				</a>
			</li>
		</ul>
	</div>
</header>

<script>
	const STORAGE_KEY = 'theme';
	const root = document.documentElement;

	const toggle = document.getElementById('nav-toggle');
	const menu = document.getElementById('mobile-menu');
	const iconOpen = document.getElementById('nav-icon-open');
	const iconClose = document.getElementById('nav-icon-close');

	const themeToggle = document.getElementById('theme-toggle');
	const themeToggleMobile = document.getElementById('theme-toggle-mobile');
	const iconMoon = document.getElementById('theme-icon-moon');
	const iconSun = document.getElementById('theme-icon-sun');

	function isDarkMode() {
		return root.classList.contains('dark');
	}

	function updateThemeIcons() {
		const dark = isDarkMode();

		if (iconMoon && iconSun) {
			iconMoon.classList.toggle('hidden', dark);
			iconSun.classList.toggle('hidden', !dark);
		}

		document.querySelectorAll('[data-theme-icon="moon"]').forEach((el) => {
			el.classList.toggle('hidden', dark);
		});
		document.querySelectorAll('[data-theme-icon="sun"]').forEach((el) => {
			el.classList.toggle('hidden', !dark);
		});

		const label = dark ? 'Prepnúť svetlý režim' : 'Prepnúť tmavý režim';
		themeToggle?.setAttribute('aria-label', label);
		themeToggleMobile?.setAttribute('aria-label', label);
	}

	function setTheme(dark) {
		root.classList.toggle('dark', dark);
		localStorage.setItem(STORAGE_KEY, dark ? 'dark' : 'light');
		updateThemeIcons();
	}

	function toggleTheme() {
		setTheme(!isDarkMode());
	}

	function initTheme() {
		const stored = localStorage.getItem(STORAGE_KEY);
		if (stored === 'dark') {
			root.classList.add('dark');
		} else if (stored === 'light') {
			root.classList.remove('dark');
		}
		updateThemeIcons();
	}

	initTheme();

	themeToggle?.addEventListener('click', toggleTheme);
	themeToggleMobile?.addEventListener('click', toggleTheme);

	if (toggle && menu && iconOpen && iconClose) {
		toggle.addEventListener('click', () => {
			const isOpen = !menu.classList.contains('hidden');
			menu.classList.toggle('hidden', isOpen);
			iconOpen.classList.toggle('hidden', !isOpen);
			iconClose.classList.toggle('hidden', isOpen);
			toggle.setAttribute('aria-expanded', String(!isOpen));
			toggle.setAttribute('aria-label', isOpen ? 'Otvoriť menu' : 'Zavrieť menu');
		});

		menu.querySelectorAll('a').forEach((link) => {
			link.addEventListener('click', () => {
				menu.classList.add('hidden');
				iconOpen.classList.remove('hidden');
				iconClose.classList.add('hidden');
				toggle.setAttribute('aria-expanded', 'false');
				toggle.setAttribute('aria-label', 'Otvoriť menu');
			});
		});
	}
</script>
