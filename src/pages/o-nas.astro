---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';

const values = [
	{
		title: 'Rýchla realizácia',
		description: 'Dohodneme termín, prídeme načas a práce spravíme efektívne bez zbytočných prestojov.',
		icon: 'bolt',
	},
	{
		title: 'Osobný prístup',
		description: 'Jeden kontakt, jasná dohoda a priebežné informovanie o postupe.',
		icon: 'users',
	},
	{
		title: 'Bezpečnosť a norma',
		description: 'Pracujeme odborne a podľa platných noriem — tak, aby bola inštalácia bezpečná a spoľahlivá.',
		icon: 'target',
	},
];
---

<Layout title="O nás | Elektro Novák">
	<Navbar />
	<PageHero
		eyebrow="O nás"
		title="Spoľahlivý elektrikár pre Košice a okolie"
		description="Elektro Novák poskytuje spoľahlivé elektroinštalácie pre domácnosti aj firmy v Košiciach a okolí."
		align="left"
	/>

	<section class="py-16 sm:py-20">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<ul class="grid grid-cols-1 gap-6 md:grid-cols-3 md:gap-8" role="list">
				{
					values.map((item) => (
						<li>
							<article class="h-full rounded-2xl border border-slate-100 bg-white p-8 dark:border-neutral-800 dark:bg-black">
								<span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-blue-50 text-blue-600 dark:bg-neutral-900 dark:text-accent-warm">
									{item.icon === 'bolt' && (
										<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
											<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
										</svg>
									)}
									{item.icon === 'users' && (
										<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"
											/>
										</svg>
									)}
									{item.icon === 'target' && (
										<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75" aria-hidden="true">
											<path
												stroke-linecap="round"
												stroke-linejoin="round"
												d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
											/>
										</svg>
									)}
								</span>
								<h2 class="mt-5 text-lg font-bold text-slate-900 dark:text-white">{item.title}</h2>
								<p class="mt-2 text-base leading-relaxed text-slate-600 dark:text-neutral-400">{item.description}</p>
							</article>
						</li>
					))
				}
			</ul>

			<div
				class="mt-12 rounded-2xl border border-slate-100 bg-slate-50 p-8 sm:p-10 dark:border-neutral-800 dark:bg-neutral-950"
			>
				<p class="text-base leading-relaxed text-slate-600 sm:text-lg dark:text-neutral-400">
					Používame kvalitné materiály a osvedčené postupy, aby bola vaša elektroinštalácia bezpečná, prehľadná a
					pripravená na budúce rozšírenie. Vysvetlíme vám možnosti, dohodneme postup a po dokončení odovzdáme
					prácu čisto a zrozumiteľne.
				</p>
				<a
					href="/kontakt"
					class="mt-8 inline-flex items-center gap-2 text-sm font-semibold text-yellow-600 transition-colors hover:text-yellow-700 dark:text-yellow-400 dark:hover:text-white"
				>
					Chcete cenovú ponuku?
					<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
					</svg>
				</a>
			</div>
		</div>
	</section>

	<Footer />
</Layout>
